LOG_DIR=.logs
# Log texto do servidor MCP (uvicorn). Default: MCP_SERVER_LOG=mcp-server.log sob LOG_DIR
# MCP_SERVER_LOG=mcp-server.log
LOG_LEVEL=INFO
MOCKS_DIR=mocks
OPENAI_API_KEY=your_openai_api_key
MCP_URL=http://127.0.0.1:8005/mcp
MCP_AUTOSTART=1
# Se a API já estiver rodando, defina 0 para o CLI não subir o uvicorn do app_mock.
TICKETS_API_URL=http://127.0.0.1:8001/tickets
KB_API_URL=http://127.0.0.1:8003/kb
# TICKETS_MOCK_AUTOSTART=0
